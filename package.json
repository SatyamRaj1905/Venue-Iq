{
  "name": "venueiq",
  "version": "1.0.0",
  "private": true,
  "description": "VenueIQ — one intelligent layer for safer, smoother, and more inclusive tournament days.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SatyamRaj1905/Venue-Iq.git"
  },
  "homepage": "https://github.com/SatyamRaj1905/Venue-Iq#readme",
  "bugs": {
    "url": "https://github.com/SatyamRaj1905/Venue-Iq/issues"
  },
  "keywords": [
    "venue-intelligence",
    "generative-ai",
    "gemini",
    "nextjs",
    "accessibility",
    "stadium-operations",
    "hackathon"
  ],
  "packageManager": "npm@11.13.0",
  "engines": {
    "node": "24.x",
    "npm": ">=11.0.0"
  },
  "scripts": {
    "dev": "cross-env NEXT_TELEMETRY_DISABLED=1 next dev",
    "build": "cross-env NEXT_TELEMETRY_DISABLED=1 next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "cross-env NODE_ENV=test vitest run --coverage",
    "test:unit": "cross-env NODE_ENV=test vitest run",
    "test:watch": "cross-env NODE_ENV=test vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:a11y": "playwright test tests/accessibility",
    "bundle:check": "node scripts/check-bundle-budget.mjs",
    "verify": "npm run format:check && npm run lint && npm run type-check && npm run test && npm run build && npm run bundle:check",
    "verify:full": "npm run verify && npm run test:e2e",
    "audit:prod": "npm audit --omit=dev",
    "vercel-build": "npm run lint && npm run type-check && npm run test && npm run build && npm run bundle:check"
  },
  "dependencies": {
    "@google/genai": "2.11.0",
    "@upstash/ratelimit": "2.0.8",
    "@upstash/redis": "1.38.0",
    "lucide-react": "1.24.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "server-only": "0.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "axe-core": "4.12.1",
    "cross-env": "10.1.0",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "eslint-plugin-promise": "7.3.0",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  },
  "overrides": {
    "postcss": "8.5.19"
  }
}
